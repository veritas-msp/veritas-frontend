# Veritas Frontend — environment variables
# Copy this file to .env or use the setup wizard (/setup)

# Backend API URL (without /api; added automatically by config.js)
REACT_APP_API_BASE_URL=http://localhost:3001

# Edition: community (OSS) or pro (commercial license)
# For local Pro: REACT_APP_VERITAS_EDITION=pro then restart the frontend (npm start)
REACT_APP_VERITAS_EDITION=community

# Marketing website (Pro pricing links, Add module modal, Administration → License)
# REACT_APP_VERITAS_WEBSITE_URL=https://veritas-msp.com

# Community support (Assistance page)
# REACT_APP_VERITAS_DISCORD_URL=https://discord.gg/Ewu3jfWhbJ
# REACT_APP_VERITAS_GITHUB_REPO=https://github.com/veritas-msp/veritas
